{
  "name": "palate",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/content": "^3.12.0",
    "@nuxt/image": "^1.10.0",
    "@pinia/nuxt": "^0.11.3",
    "drizzle-orm": "^0.40.0",
    "nuxt": "^4.0.0",
    "pinia": "^3.0.0",
    "postgres": "^3.4.5",
    "vue": "^3.5.0",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.3",
    "@nuxt/eslint": "^1.4.0",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.30.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
