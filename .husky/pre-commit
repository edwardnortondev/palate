branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo "\n\033[31m✖ Direct commits to $branch are not allowed.\033[0m"
  echo "  Create a feature branch: git checkout -b feat/your-change\n"
  exit 1
fi

pnpm exec lint-staged
pnpm typecheck
pnpm test:unit
